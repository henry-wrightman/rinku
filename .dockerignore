# Ignore everything except what's needed for Rust build
*

# Include Cargo files
!Cargo.toml
!Cargo.lock

# Include Rust packages
!packages/rinku-core
!packages/rinku-node

# Include activity bot build inputs
!package.json
!package-lock.json
!tsconfig.base.json
!scripts
!scripts/**
!packages/core
!packages/core/**
!packages/wallet
!packages/wallet/**

# Exclude build artifacts
packages/rinku-core/target
packages/rinku-node/target
target

# Exclude node_modules and TS packages
packages/explorer
packages/faucet
packages/node

# Exclude other files
.git
.gitignore
*.md
docs
attached_assets
node_modules
.local
