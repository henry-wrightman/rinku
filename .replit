modules = ["nodejs-20"]
[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Rinku Services"

[[workflows.workflow]]
name = "Rinku Services"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build -w @rinku/core && (npm run dev -w @rinku/node & npm run dev -w @rinku/faucet & npm run dev -w @rinku/explorer)"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3002
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[nix]
channel = "stable-25_05"

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "cd packages/node && node dist/index.js & cd packages/faucet && node dist/index.js & cd packages/explorer && npx vite preview --host 0.0.0.0 --port 5000"]
build = ["bash", "-c", "npm run build -w @rinku/core && npm run build -w @rinku/node && npm run build -w @rinku/faucet && npm run build -w @rinku/explorer"]
