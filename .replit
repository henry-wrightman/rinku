modules = ["nodejs-20", "rust-stable"]
[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Rinku Explorer"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Rinku Faucet"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Rinku Rust Node"

[[workflows.workflow]]
name = "Rinku Explorer"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build -w @rinku/core && npm run dev -w @rinku/explorer"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Rinku Faucet"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev -w @rinku/faucet"
waitForPort = 3002

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Rinku Rust Node"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "RUST_LOG=\"rinku_node=info,rinku_node::gossip=info\" cargo run -p rinku-node"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3002
externalPort = 5000

[[ports]]
localPort = 3003
externalPort = 5173

[[ports]]
localPort = 3011
externalPort = 8000

[[ports]]
localPort = 3012
externalPort = 8080

[[ports]]
localPort = 3013
externalPort = 8099

[[ports]]
localPort = 4001
externalPort = 3003

[[ports]]
localPort = 4002
externalPort = 4200

[[ports]]
localPort = 4003
externalPort = 3002

[[ports]]
localPort = 4011
externalPort = 6800

[[ports]]
localPort = 4012
externalPort = 8008

[[ports]]
localPort = 4013
externalPort = 8081

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 9999
externalPort = 6000

[[ports]]
localPort = 9999
externalPort = 6000

[nix]
channel = "stable-25_05"
packages = [
  "nettools",
  "rustc",
  "circom",
  "openssl",
  "pkg-config",
  "pandoc",
  "jq",
  "cmake",
  "clang",
  "libclang",
  "llvmPackages.libclang",
]

[deployment]
deploymentTarget = "autoscale"
run = ["./rinku-node-bin"]
build = [
  "bash",
  "-c",
  "rm -f rinku-node-bin; cargo build --release -p rinku-node --no-default-features && cp target/release/rinku-node rinku-node-bin && rm -rf target && npm run build -w @rinku/core && npm run build -w @rinku/explorer",
]

[userenv]

[userenv.production]
STATIC_DIR = "packages/explorer/dist"
API_PORT = "5000"
NODE_PEERS = "https://rinku-node.fly.dev"

[userenv.shared]
PUBLIC_URL = "https://rinkuchan.com"
