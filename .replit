modules = ["nodejs-20", "rust-stable"]
[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Rinku Rust Node"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Rinku Explorer"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Rinku Faucet"

[[workflows.workflow]]
name = "Rinku Rust Node"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cargo run -p rinku-node"
waitForPort = 3001

[[workflows.workflow]]
name = "Rinku Explorer"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build -w @rinku/core && npm run dev -w @rinku/explorer"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Rinku Faucet"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev -w @rinku/faucet"
waitForPort = 3002

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3002
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[nix]
channel = "stable-25_05"
packages = ["nettools", "rustc", "circom", "openssl", "pkg-config", "pandoc"]

[deployment]
deploymentTarget = "autoscale"
run = ["./rinku-node-bin"]
build = [
  "bash",
  "-c",
  "rm -f rinku-node-bin; cargo build --release --no-default-features -p rinku-node && cp target/release/rinku-node rinku-node-bin && rm -rf target && npm run build -w @rinku/core && npm run build -w @rinku/explorer",
]

[userenv]

[userenv.production]
STATIC_DIR = "packages/explorer/dist"
API_PORT = "5000"
