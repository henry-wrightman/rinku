modules = ["nodejs-20", "rust-stable"]
[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Rinku Services"

[[workflows.workflow]]
name = "Rinku Services"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build -w @rinku/core && (npm run dev -w @rinku/node & npm run dev -w @rinku/faucet & sleep 3 && npm run dev -w @rinku/explorer)"
waitForPort = 5000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3002
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[nix]
channel = "stable-25_05"
packages = ["nettools", "rustc", "circom", "openssl", "pkg-config"]

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "node packages/node/dist/index.js & node packages/faucet/dist/index.js & cd packages/explorer && npx vite preview --host 0.0.0.0 --port 5000"]
build = ["npm", "run", "build"]
