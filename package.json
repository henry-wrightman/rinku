{
  "name": "rinku",
  "version": "0.1.0",
  "private": true,
  "description": "A URL-native distributed ledger with DAG-based consensus",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test -w @rinku/core && npm run test -w @rinku/node",
    "test:core": "npm run test -w @rinku/core",
    "test:node": "npm run test -w @rinku/node",
    "dev:node": "npm run dev -w @rinku/node",
    "dev:explorer": "npm run dev -w @rinku/explorer",
    "dev:faucet": "npm run dev -w @rinku/faucet",
    "validate": "npx tsx scripts/validate-testnet.ts",
    "stress-test": "npx tsx scripts/stress-test.ts"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@types/express-rate-limit": "^5.1.3",
    "express-rate-limit": "^8.2.1",
    "prom-client": "^15.1.3",
    "tsx": "^4.21.0",
    "vitest": "^4.0.16"
  }
}
