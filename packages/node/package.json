{
  "name": "@rinku/node",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "node --expose-gc --import tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "stress-test": "tsx src/stress-test.ts",
    "simulate": "tsx src/simulate-network.ts",
    "activity-bot": "tsx src/activity-bot.ts",
    "demo-contract": "tsx src/demo-contract.ts",
    "demo-rewards": "tsx src/demo-rewards.ts",
    "demo-finality": "tsx src/demo-finality.ts"
  },
  "dependencies": {
    "@rinku/core": "*",
    "@rinku/wallet": "*",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@vitest/coverage-v8": "^4.0.16",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
