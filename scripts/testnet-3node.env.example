# Rinku 3-Node Testnet Configuration
# Copy this file and rename for each node

# ==============================================================================
# NODE 1: Replit (https://rinkuchan.com)
# Set these in Replit Secrets
# ==============================================================================
# NODE_PEERS=https://rinku-fly.fly.dev

# ==============================================================================
# NODE 2: Local Mac
# Run with: source scripts/testnet-3node.env.local && cargo run -p rinku-node
# ==============================================================================
# RINKU_PORT=3001
# NODE_PEERS=https://rinkuchan.com,https://rinku-fly.fly.dev
# RINKU_DB_PATH=./rinku-local-data
# RUST_LOG=info

# ==============================================================================
# NODE 3: Fly.io (https://rinku-fly.fly.dev)  
# Set these in fly.toml [env] section
# ==============================================================================
# RINKU_PORT=8080
# NODE_PEERS=https://rinkuchan.com
# RUST_LOG=info

# ==============================================================================
# Quick Start Commands
# ==============================================================================
# 
# Local Mac:
#   RINKU_PORT=3001 NODE_PEERS="https://rinkuchan.com" cargo run -p rinku-node
#
# Validate all nodes:
#   npx ts-node scripts/validate-multi-node.ts https://rinkuchan.com http://localhost:3001
#
# Generate proofs:
#   npx ts-node scripts/generate-proofs.ts https://rinkuchan.com --count 5
