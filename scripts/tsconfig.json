{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "downlevelIteration": true,
    "outDir": "./dist"
  },
  "include": ["./*.ts"],
  "references": [
    { "path": "../packages/core" }
  ]
}
